# Cloudflare Tunnel token created in the Zero Trust dashboard
# (Networks > Tunnels > your tunnel > Install connector).
# Copy this file to .env and fill in the token.
TUNNEL_TOKEN=

# MaxMind GeoIP credentials (https://www.maxmind.com/en/accounts/current/license-key).
# Used by the geoipupdate service to download GeoLite2 databases.
GEOIPUPDATE_ACCOUNT_ID=
GEOIPUPDATE_LICENSE_KEY=
